# Catppuccin Latte for zsh-syntax-highlighting
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[command]='fg=#1E66F5'           # blue
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#1E66F5'           # blue
ZSH_HIGHLIGHT_STYLES[alias]='fg=#1E66F5'             # blue
ZSH_HIGHLIGHT_STYLES[function]='fg=#1E66F5'          # blue
ZSH_HIGHLIGHT_STYLES[precommand]='fg=#40A02B,italic' # green
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=#EA76CB'  # pink
ZSH_HIGHLIGHT_STYLES[path]='fg=#4C4F69,underline'    # text
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=#DF8E1D' # yellow
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=#DF8E1D' # yellow
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#40A02B' # green
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#40A02B' # green
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=#40A02B' # green
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=#EA76CB'   # pink
ZSH_HIGHLIGHT_STYLES[redirection]='fg=#D20F39'       # red
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#DF8E1D'          # yellow
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#D20F39'     # red
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#8839EF'     # mauve
ZSH_HIGHLIGHT_STYLES[comment]='fg=#9CA0B0,italic'    # overlay0
ZSH_HIGHLIGHT_STYLES[assign]='fg=#4C4F69'            # text
ZSH_HIGHLIGHT_STYLES[suffix-alias]='fg=#40A02B,underline' # green

# zsh-autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#9CA0B0'         # overlay0 (subtle)
