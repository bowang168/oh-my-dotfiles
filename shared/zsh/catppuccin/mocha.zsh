# Catppuccin Mocha for zsh-syntax-highlighting
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[command]='fg=#89B4FA'           # blue
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#89B4FA'           # blue
ZSH_HIGHLIGHT_STYLES[alias]='fg=#89B4FA'             # blue
ZSH_HIGHLIGHT_STYLES[function]='fg=#89B4FA'          # blue
ZSH_HIGHLIGHT_STYLES[precommand]='fg=#A6E3A1,italic' # green
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=#F5C2E7'  # pink
ZSH_HIGHLIGHT_STYLES[path]='fg=#CDD6F4,underline'    # text
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=#F9E2AF' # yellow
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=#F9E2AF' # yellow
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#A6E3A1' # green
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#A6E3A1' # green
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=#A6E3A1' # green
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=#F5C2E7'   # pink
ZSH_HIGHLIGHT_STYLES[redirection]='fg=#F38BA8'       # red
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#F9E2AF'          # yellow
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#F38BA8'     # red
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#CBA6F7'     # mauve
ZSH_HIGHLIGHT_STYLES[comment]='fg=#6C7086,italic'    # overlay0
ZSH_HIGHLIGHT_STYLES[assign]='fg=#CDD6F4'            # text
ZSH_HIGHLIGHT_STYLES[suffix-alias]='fg=#A6E3A1,underline' # green

# zsh-autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#6C7086'         # overlay0 (subtle)
